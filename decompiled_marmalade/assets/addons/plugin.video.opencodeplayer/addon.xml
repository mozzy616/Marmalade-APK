<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.opencodeplayer" name="Open Code Player" version="1.0.0" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Open Code Player</summary>
        <description lang="en_GB">Paste any torrent or magnet link and stream it instantly.</description>
        <platform>all</platform>
        <license>MIT</license>
    </extension>
</addon>
