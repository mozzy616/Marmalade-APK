<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.build.extractor" name="Build Extractor" version="1.0.0" provider-name="Custom">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.service" library="default.py" start="startup"/>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">Extracts custom build on first run</summary>
    <description lang="en">Automatically extracts the bundled custom Kodi build from assets into the userdata directory.</description>
    <platform>all</platform>
  </extension>
</addon>