<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.autoenable" name="Auto Enable Services" version="1.0.0" provider-name="marmalade">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Auto-enable addons on startup</summary>
        <description lang="en_GB">Ensures Torrest and Open Code Player are enabled when Kodi starts.</description>
        <platform>all</platform>
    </extension>
</addon>
