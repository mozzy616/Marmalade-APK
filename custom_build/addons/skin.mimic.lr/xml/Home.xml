<?xml version="1.0" encoding="utf-8"?>
<window>
    <defaultcontrol always="true">9000</defaultcontrol>
    <allowoverlay>no</allowoverlay>
    <onload>SetProperty(CurrentSkin,skin.mimic.lr,home)</onload>
    <onload>RunScript(script.skinshortcuts,type=buildxml&amp;mode=single&amp;options=clonewidgets&amp;mainmenuID=9000&amp;group=mainmenu|quicknav)</onload>

    <onload>ClearProperty(MediaMenu,Home)</onload>
    <onunload condition="!Skin.HasSetting(Enable.HorizontalMenu) + Skin.HasSetting(Enable.CombineMenus)">RunScript(script.skinshortcuts,type=hidesubmenu&amp;mainmenuID=9000)</onunload>
    <controls>
        <control type="wraplist" id="9033">
            <include>HiddenList</include>
            <content>$INFO[Container(9010).ListItem.Property(backgroundPlaylist)]</content>
            <autoscroll time="7000" delay="7000" repeat="7000">!Skin.HasSetting(Disable.AutoScroll) + String.IsEqual(Container(9010).ListItem.Property(background),playlistBackground)</autoscroll>
            <visible>String.IsEqual(Container(9010).ListItem.Property(background),playlistBackground)</visible>
        </control>
        <control type="wraplist" id="9034">
            <include>HiddenList</include>
            <content>$INFO[Container(9000).ListItem.Property(backgroundPlaylist)]</content>
            <autoscroll time="7000" delay="7000" repeat="7000">!Skin.HasSetting(Disable.AutoScroll) + String.IsEqual(Container(9000).ListItem.Property(background),playlistBackground)</autoscroll>
            <visible>String.IsEqual(Container(9000).ListItem.Property(background),playlistBackground)</visible>
        </control>
        <control type="multiimage">
            <include>FullscreenDimensions</include>
            <include>BackgroundFadeAnimation</include>
            <imagepath background="true">$VAR[HomeBackgroundVar]</imagepath>
        </control>
        <include>skinshortcuts-template-WidgetFanart</include>
        <control type="visualisation">
            <visible>Player.HasAudio + !Skin.HasSetting(Disable.ShowBackgroundVis) + !SlideShow.IsActive</visible>
            <include>FullscreenDimensions</include>
        </control>
        <control type="group">
            <visible>Player.HasVideo + !Skin.HasSetting(Disable.ShowBackgroundVideo) + !SlideShow.IsActive</visible>
            <control type="image">
                <include>FullscreenDimensions</include>
                <texture>black.png</texture>
            </control>
            <control type="videowindow">
                <include>FullscreenDimensions</include>
            </control>
        </control>
        <control type="image">
            <include>FullscreenDimensions</include>
            <texture>$VAR[CommonBackgroundOverlay]</texture>
            <colordiffuse>BackgroundColor</colordiffuse>
        </control>
        <include>Topbar</include>
        <include condition="!Skin.HasSetting(Enable.HorizontalMenu)">HomeVertical</include>
        <include condition="Skin.HasSetting(Enable.HorizontalMenu)">HomeHorizontal</include>
        <control type="label">
            <visible>![Window.IsVisible(favouritesbrowser) | Window.IsVisible(script-globalsearch-main.xml) | Window.IsVisible(script-lazytv-main.xml) | Window.IsVisible(script-lazytv-BigScreenList.xml)]</visible>
            <animation effect="slide" time="0" start="0,0" end="-212,-60" condition="Skin.HasSetting(Enable.HorizontalMenu)">Conditional</animation>
            <include>Animation.Common</include>
            <top>210</top>
            <left>594</left>
            <width>1200</width>
            <height>780</height>
            <align>center</align>
            <label>$VAR[HomeEmptyLibrary]</label>
            <font>font16</font>
            <wrapmultiline>true</wrapmultiline>
        </control>
		<include>weather-details-zoom</include>
        <!-- Marmalade Build Logo - Top Center with Animation -->
        <control type="group">
            <centerleft>50%</centerleft>
            <top>80</top>
            <width>80</width>
            <height>80</height>
            <!-- Fade in on open -->
            <animation effect="fade" start="0" end="100" time="400" delay="200">WindowOpen</animation>
            <!-- Pulse animation -->
            <animation effect="zoom" start="100" end="108" center="auto" time="1500" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
            <!-- Float effect -->
            <animation effect="slide" start="0,-5" end="0,5" time="2000" tween="sine" easing="inout" pulse="true" condition="true">Conditional</animation>
            
            <control type="image">
                <width>80</width>
                <height>80</height>
                <texture>marmalade_icon.png</texture>
                <aspectratio align="center" aligny="center">keep</aspectratio>
            </control>
        </control>
    </controls>
</window>