<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.opencodeplayer" name="Open Code Player" version="2.0.0" provider-name="opencode">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>video</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Open Code Player</summary>
        <description lang="en_GB">Search and stream movies and TV shows via magnet links from multiple sources.</description>
        <platform>all</platform>
        <license>MIT</license>
        <news>v2.0.0
- Added new logo and fanart
- Multi-page search from 3 sources
- Improved result sorting</news>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
            <screenshot>resources/screenshots/screenshot1.jpg</screenshot>
            <screenshot>resources/screenshots/screenshot2.jpg</screenshot>
        </assets>
    </extension>
</addon>
